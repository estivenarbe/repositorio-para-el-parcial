CONTEXTO:
---------
Debes analizar textos usando conjuntos para comparar palabras.

INSTRUCCIONES:
--------------
1. Convertir textos a conjuntos
2. Aplicar operaciones de conjuntos
3. Validar entradas
4. Implementar análisis completo
5. Tiempo: 90 minutos
"""


class AnalizadorTexto:
    def __init__(self, texto):
        """
        👉 SI EL PROFESOR ME PIDE PROCESAR TEXTO:

        1. Validar texto
        2. Convertir a minúsculas
        3. Separar palabras
        4. Convertir a set
        """

        if not texto:
            raise ValueError("Texto vacío")

        self.texto = texto
        self.palabras = set(texto.lower().split())

    def palabras_comunes(self, otro):
        """
        👉 INTERSECCIÓN
        """

        return self.palabras & otro.palabras

    def palabras_unicas(self, otro):
        """
        👉 DIFERENCIA SIMÉTRICA
        """

        return self.palabras ^ otro.palabras

    def solo_en_este(self, otro):
        """
        👉 DIFERENCIA
        """

        return self.palabras - otro.palabras

    def es_subconjunto(self, otro):
        """
        👉 SUBCONJUNTO
        """

        return self.palabras <= otro.palabras

    def son_disjuntos(self, otro):
        """
        👉 DISJUNTOS
        """

        return self.palabras.isdisjoint(otro.palabras)

    def todas_palabras(self, otro):
        """
        👉 UNIÓN
        """

        return self.palabras | otro.palabras


# ================== PRUEBAS ==================
if __name__ == "__main__":
    texto1 = AnalizadorTexto("python es un lenguaje de programacion")
    texto2 = AnalizadorTexto("java es otro lenguaje de programacion")

    print("\n🔗 Comunes:", texto1.palabras_comunes(texto2))
    print("🌐 Todas:", texto1.todas_palabras(texto2))
    print("❌ Solo en texto1:", texto1.solo_en_este(texto2))
    print("⚡ Diferencia simétrica:", texto1.palabras_unicas(texto2))
    print("📌 Subconjunto:", texto1.es_subconjunto(texto2))
    print("🚫 Disjuntos:", texto1.son_disjuntos(texto2))
