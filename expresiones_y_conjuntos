CONTEXTO:
---------
Una universidad necesita gestionar estudiantes inscritos en cursos.

Cada curso tiene un conjunto de estudiantes (sin duplicados).

INSTRUCCIONES:
--------------
1. Usar conjuntos (set)
2. Implementar operaciones entre conjuntos
3. Validar datos de entrada
4. Resolver consultas académicas
5. Tiempo: 90 minutos
"""


class SistemaCursos:
    def __init__(self):
        """
        👉 SI EL PROFESOR ME PIDE USAR CONJUNTOS:

        1. Cada curso será un set
        2. Uso diccionario para organizar cursos
        """
        self.cursos = {}

    def crear_curso(self, nombre):
        """
        👉 CREAR CURSO:

        1. Validar nombre
        2. Crear set vacío
        """

        if not nombre:
            raise ValueError("Nombre inválido")

        if nombre in self.cursos:
            raise ValueError("Curso ya existe")

        self.cursos[nombre] = set()

    def agregar_estudiante(self, curso, estudiante):
        """
        👉 AGREGAR:

        1. Validar curso
        2. Usar add()
        """

        if curso not in self.cursos:
            raise ValueError("Curso no existe")

        if not estudiante:
            raise ValueError("Estudiante inválido")

        self.cursos[curso].add(estudiante)

    def estudiantes_comunes(self, curso1, curso2):
        """
        👉 INTERSECCIÓN:

        A ∩ B
        """

        return self.cursos[curso1] & self.cursos[curso2]

    def todos_estudiantes(self, curso1, curso2):
        """
        👉 UNIÓN:

        A ∪ B
        """

        return self.cursos[curso1] | self.cursos[curso2]

    def solo_en_curso(self, curso1, curso2):
        """
        👉 DIFERENCIA:

        A - B
        """

        return self.cursos[curso1] - self.cursos[curso2]

    def verificar_subconjunto(self, curso1, curso2):
        """
        👉 RELACIÓN:

        A ⊆ B
        """

        return self.cursos[curso1] <= self.cursos[curso2]

    def son_disjuntos(self, curso1, curso2):
        """
        👉 DISJUNTOS:

        No tienen elementos en común
        """

        return self.cursos[curso1].isdisjoint(self.cursos[curso2])

    def mostrar(self):
        for curso, estudiantes in self.cursos.items():
            print(f"{curso}: {estudiantes}")


# ================== PRUEBAS ==================
if __name__ == "__main__":
    sistema = SistemaCursos()

    sistema.crear_curso("Matematicas")
    sistema.crear_curso("Programacion")

    sistema.agregar_estudiante("Matematicas", "Juan")
    sistema.agregar_estudiante("Matematicas", "Ana")

    sistema.agregar_estudiante("Programacion", "Ana")
    sistema.agregar_estudiante("Programacion", "Carlos")

    print("\n📋 Cursos:")
    sistema.mostrar()

    print("\n🔗 Comunes:", sistema.estudiantes_comunes("Matematicas", "Programacion"))
    print("🌐 Todos:", sistema.todos_estudiantes("Matematicas", "Programacion"))
    print("❌ Solo en Mat:", sistema.solo_en_curso("Matematicas", "Programacion"))
    print("📌 Subconjunto:", sistema.verificar_subconjunto("Matematicas", "Programacion"))
    print("🚫 Disjuntos:", sistema.son_disjuntos("Matematicas", "Programacion"))
